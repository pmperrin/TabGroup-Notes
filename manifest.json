{
  "manifest_version": 3,
  "name": "Tab Group Post-its",
  "version": "1.0",
  "description": "Ajoute des post-it à vos groupes d'onglets pour un suivi rapide de vos tâches.",
  "permissions": [
    "tabGroups",
    "storage",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Ouvrir les post-it"
  },
  "background": {
    "service_worker": "background.js"
  }
}
